{
    "name": "paulstretch",
    "author": "Isabel Kaspriskie",
    "description": "Paulstretch stretching algorithm for Max",
    "max_version_min": "8.2",
    "max_version_max": "none",
    "os": {
        "macintosh": {
            "platform": [
                "x64",
                "aarch64"
            ],
            "min_version": "10.11.x"
        },
        "windows": {
            "platform": [
                "x64"
            ],
            "min_version": "8"
        }
    },
    "package_extra": {
        "reverse_domain": "com.isabelgk.max.paulstretch",
        "copyright": "Copyright (c) 2026 Isabel Kaspriskie"
    },
    "version": "@PACKAGE_VERSION@",
    "website": "http://www.github.com/isabelgk/max-paulstretch"
}
